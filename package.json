{
  "name": "@pharos-lab/lantern",
  "private": false,
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/lantern.umd.cjs",
  "module": "./dist/lantern.js",
  "exports": {
    ".": {
      "import": "./dist/lantern.js",
      "require": "./dist/lantern.umd.cjs"
    }
