  "dependencies": {
    "@heroicons/vue": "^2.0.18",
    "@pharos-lab/blink": "^0.1.2",
    "autoprefixer": "^10.4.13",
    "postcss": "^8.4.21",
    "vue": "^3.2.45"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.3",
    "@vitejs/plugin-vue": "^4.0.0",
    "tailwindcss": "^3.2.4",
    "vite": "^4.1.0-beta.1"
  }
